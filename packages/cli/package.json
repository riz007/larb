{
  "name": "@larb/cli",
  "version": "0.1.0-alpha.2",
  "description": "Larb CLI + TUI — open-source, model-agnostic, security-first autonomous coding agent",
  "keywords": [
    "coding-agent",
    "ai-agent",
    "autonomous-agent",
    "agentic",
    "llm",
    "cli",
    "tui",
    "developer-tools",
    "model-agnostic",
    "anthropic",
    "openai",
    "ollama",
    "open-source"
  ],
  "license": "Apache-2.0",
  "homepage": "https://riz007.github.io/larb/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/riz007/larb.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/riz007/larb/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "larb": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "node ../../scripts/build.mjs"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "comment": "dist bundles the @larb/* workspace source, so only the third-party closure is a runtime dependency; the workspace packages are build-time devDependencies.",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "diff": "^7.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "smol-toml": "^1.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@larb/context": "workspace:*",
    "@larb/core": "workspace:*",
    "@larb/governors": "workspace:*",
    "@larb/mcp": "workspace:*",
    "@larb/providers": "workspace:*",
    "@larb/sandbox": "workspace:*",
    "@larb/skills": "workspace:*",
    "@types/react": "^18.3.18"
  }
}
